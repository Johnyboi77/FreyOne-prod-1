### 7.3 Token Management im Frontend

```typescript
// lib/auth.ts
let inMemoryAccessToken: string | null = null;

// Access Token nur im Memory (nie localStorage – XSS Schutz)
export const setAccessToken = (token: string) => { inMemoryAccessToken = token; };
export const getAccessToken = () => inMemoryAccessToken;
export const clearAccessToken = () => { inMemoryAccessToken = null; };

// Refresh läuft über httpOnly Cookie (automatisch mitgesendet)
export async function refreshAccessToken(): Promise<boolean> {
  const res = await fetch('/auth/refresh', { method: 'POST', credentials: 'include' });
  if (!res.ok) { clearAccessToken(); return false; }
  const { accessToken } = await res.json();
  setAccessToken(accessToken);
  return true;
}
```

### 7.4 Middleware (Next.js)

```typescript
// middleware.ts
import { NextRequest, NextResponse } from 'next/server'
import { jwtVerify } from 'jose'

export async function middleware(request: NextRequest) {
  const token = request.cookies.get('access_token')?.value
    ?? request.headers.get('Authorization')?.replace('Bearer ', '');

  if (!token) return NextResponse.redirect(new URL('/login', request.url));

  try {
    await jwtVerify(token, new TextEncoder().encode(process.env.JWT_SECRET));
    // Supabase-Session-Prüfung entfällt komplett
  } catch {
    return NextResponse.redirect(new URL('/login', request.url));
  }
}
```

