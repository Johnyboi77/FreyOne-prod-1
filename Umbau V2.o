## 9. Phase 6 – GFS Backups (Cloudflare R2)

### 9.1 rclone konfigurieren

```bash
rclone config
# → n → Name: r2 → s3 → Cloudflare
# → Access Key ID, Secret Key, Account ID
# → Endpoint: https://ACCOUNT_ID.r2.cloudflarestorage.com
```

### 9.2 GFS Backup Script

```bash
#!/bin/bash
# /home/deploy/scripts/backup.sh

R2_BUCKET="r2:freyone-backups"
DATE=$(date +%Y%m%d)
DOW=$(date +%u)
DOM=$(date +%d)
TMP="/tmp/backups"
mkdir -p $TMP

backup_db() {
  local DB=$1
  local FILE="$TMP/${DB}_${DATE}.sql.gz"
  pg_dump -U postgres -h localhost $DB | gzip > $FILE
  echo $FILE
}

# SOHN (täglich)
for DB in freyone_prod company_internal; do
  FILE=$(backup_db $DB)
  rclone copy $FILE "${R2_BUCKET}/daily/${DB}/" --quiet
done

# VATER (jeden Sonntag)
if [ "$DOW" = "7" ]; then
  WEEK=$(date +%Y-KW%V)
  for DB in freyone_prod company_internal; do
    FILE="$TMP/${DB}_weekly_${WEEK}.sql.gz"
    pg_dump -U postgres -h localhost $DB | gzip > $FILE
    rclone copy $FILE "${R2_BUCKET}/weekly/${DB}/" --quiet
  done
fi

# GROSSVATER (jeden 1. des Monats)
if [ "$DOM" = "01" ]; then
  MONTH=$(date +%Y-%m)
  for DB in freyone_prod company_internal; do
    FILE="$TMP/${DB}_monthly_${MONTH}.sql.gz"
    pg_dump -U postgres -h localhost $DB | gzip > $FILE
    rclone copy $FILE "${R2_BUCKET}/monthly/${DB}/" --quiet
  done
fi

rclone delete "${R2_BUCKET}/daily/"   --min-age 7d   --quiet
rclone delete "${R2_BUCKET}/weekly/"  --min-age 28d  --quiet
rclone delete "${R2_BUCKET}/monthly/" --min-age 365d --quiet
rm -f $TMP/*.sql.gz

echo "[$(date)] Backup abgeschlossen"
```

### 9.3 Backup Crontab

```bash
0 3 * * * /home/deploy/scripts/backup.sh >> /var/log/backup.log 2>&1
```

