    "@types/jsonwebtoken": "^9.x"
  }
}
```

Kein ORM. Kein Express. Direktes SQL über `postgres` Package.

### 5.2 Projektstruktur

```
apps/api/
  src/
    routes/
      auth.ts           ← Register, Login, Refresh, Logout, Forgot, Reset
      bookings.ts
      providers.ts
      payments.ts
      admin.ts
    crons/
      index.ts
      jobs/
    middleware/
      auth.ts           ← JWT Validation
      rateLimit.ts
      cors.ts
    db/
      client.ts         ← postgres connection via PgBouncer
      queries/
    utils/
      jwt.ts
      hash.ts           ← bcrypt Wrapper
      tokens.ts         ← Refresh Token Helpers
      mailer.ts
    index.ts
  ecosystem.config.js
  tsconfig.json
```

### 5.3 Sichere Auth-Implementierung

#### hash.ts – Passwörter hashen (bcrypt, Cost 12)

```typescript
// src/utils/hash.ts
import bcrypt from 'bcryptjs';
import crypto from 'crypto';

// Cost 12: ~400ms auf modernem Server – gut gegen Brute Force
// Cost 10 = ~100ms (zu schnell), Cost 14 = ~1.6s (zu langsam für UX)
const BCRYPT_COST = 12;

export async function hashPassword(plaintext: string): Promise<string> {
  // bcrypt.hash generiert automatisch einen zufälligen Salt
  return bcrypt.hash(plaintext, BCRYPT_COST);
}

export async function verifyPassword(
  plaintext: string,
  hash: string
): Promise<boolean> {
  // Timing-sicherer Vergleich (verhindert Timing Attacks)
  return bcrypt.compare(plaintext, hash);
}

// Für Refresh Tokens und Password Resets: SHA-256 des zufälligen Tokens
export function hashToken(token: string): string {
  return crypto.createHash('sha256').update(token).digest('hex');
}

// Zufälliges Token erzeugen (URL-safe)
export function generateToken(bytes = 64): string {
  return crypto.randomBytes(bytes).toString('base64url');
}
```

> **Warum nicht MD5/SHA für Passwörter?**
> MD5 und SHA sind extrem schnell – eine GPU schafft Milliarden Hashes pro Sekunde.
> bcrypt ist absichtlich langsam und hat einen eingebauten Salt.
> Refresh-Token-Hashes mit SHA-256 sind ok, weil das Token selbst 64 Byte Zufallsentropie hat.

#### jwt.ts – Access Token Strategie

```typescript
// src/utils/jwt.ts
import jwt from 'jsonwebtoken';

export interface JWTPayload {
  userId: string;
  role: 'customer' | 'provider' | 'admin';
}

// Access Token: 15 Minuten – kurze Lifetime schützt bei Leak
export function signAccessToken(payload: JWTPayload): string {
  return jwt.sign(payload, process.env.JWT_SECRET!, { expiresIn: '15m' });
}

// Verify wirft bei abgelaufenem oder manipuliertem Token
export function verifyAccessToken(token: string): JWTPayload {
  return jwt.verify(token, process.env.JWT_SECRET!) as JWTPayload;
}
```

#### tokens.ts – Refresh Token Helpers

```typescript
// src/utils/tokens.ts
import { generateToken, hashToken } from './hash';
import { db } from '../db/client';

const REFRESH_TOKEN_TTL_DAYS = 7;

export async function createRefreshToken(
  userId: string,
  ipAddress: string,
  userAgent: string
): Promise<string> {
  const rawToken = generateToken(64);       // 64 Byte = 512 Bit Entropie
  const tokenHash = hashToken(rawToken);   // SHA-256 davon in DB

  const expiresAt = new Date();
  expiresAt.setDate(expiresAt.getDate() + REFRESH_TOKEN_TTL_DAYS);

  await db.none(`
    INSERT INTO refresh_tokens (user_id, token_hash, ip_address, user_agent, expires_at)
    VALUES ($1, $2, $3::inet, $4, $5)
  `, [userId, tokenHash, ipAddress, userAgent, expiresAt]);

  return rawToken; // Nur dieser eine Moment – danach nie wieder sichtbar
}

export async function rotateRefreshToken(
  rawToken: string,
  ipAddress: string,
  userAgent: string
): Promise<{ userId: string; newRawToken: string } | null> {
  const incomingHash = hashToken(rawToken);

  const existing = await db.oneOrNone(`
    SELECT id, user_id, expires_at, replaced_by
    FROM refresh_tokens
    WHERE token_hash = $1
  `, [incomingHash]);

  // Token existiert nicht
  if (!existing) return null;

  // Token wurde bereits rotiert → Reuse-Angriff!
  // Alle Tokens dieses Users invalidieren (Token-Familie kompromittiert)
  if (existing.replaced_by) {
    await db.none(`DELETE FROM refresh_tokens WHERE user_id = $1`, [existing.user_id]);
    return null;
  }

  // Token abgelaufen
  if (new Date(existing.expires_at) < new Date()) {
    await db.none(`DELETE FROM refresh_tokens WHERE id = $1`, [existing.id]);
    return null;
  }

  // Neues Token ausstellen
  const newRawToken = generateToken(64);
  const newHash = hashToken(newRawToken);
  const expiresAt = new Date();
  expiresAt.setDate(expiresAt.getDate() + REFRESH_TOKEN_TTL_DAYS);

  await db.tx(async t => {
    // Neues Token einfügen
    const newRecord = await t.one(`
      INSERT INTO refresh_tokens (user_id, token_hash, ip_address, user_agent, expires_at)
      VALUES ($1, $2, $3::inet, $4, $5)
      RETURNING id
    `, [existing.user_id, newHash, ipAddress, userAgent, expiresAt]);

    // Altes Token als ersetzt markieren (für Reuse-Detection)
    await t.none(`
      UPDATE refresh_tokens SET replaced_by = $1 WHERE id = $2
    `, [newRecord.id, existing.id]);
  });

  return { userId: existing.user_id, newRawToken };
}
```

### 5.4 Auth Endpoints – vollständige Implementierung

```typescript
// src/routes/auth.ts
import { Hono } from 'hono';
import { zValidator } from '@hono/zod-validator';
import { z } from 'zod';
import { setCookie, deleteCookie } from 'hono/cookie';
import { db } from '../db/client';
import {
  hashPassword, verifyPassword,
  generateToken, hashToken
} from '../utils/hash';
import {
  signAccessToken, verifyAccessToken
} from '../utils/jwt';
import {
  createRefreshToken, rotateRefreshToken
} from '../utils/tokens';
import { sendVerificationEmail, sendPasswordResetEmail } from '../utils/mailer';

const auth = new Hono();

// ─── POST /auth/register ─────────────────────────────────────────────────────
const registerSchema = z.object({
  email:     z.string().email().toLowerCase(),
  password:  z.string().min(8).max(128),
  firstName: z.string().min(1).max(100),
  lastName:  z.string().min(1).max(100),
});

auth.post('/register', zValidator('json', registerSchema), async (c) => {
  const { email, password, firstName, lastName } = c.req.valid('json');

  // Existiert der User bereits?
  const existing = await db.oneOrNone(
    `SELECT id FROM users WHERE email = $1`, [email]
  );
  if (existing) {
    // Gleiche Fehlermeldung wie bei nicht-existentem User (verhindert User-Enumeration)
    return c.json({ message: 'Registrierung erfolgreich. Bitte E-Mail bestätigen.' }, 201);
  }

  const passwordHash = await hashPassword(password);

  // users + profiles in einer Transaction – beide oder keins
  const userId = await db.tx(async t => {
    const user = await t.one(`
      INSERT INTO users (email, password_hash, role)
      VALUES ($1, $2, 'customer')
      RETURNING id
    `, [email, passwordHash]);

    await t.none(`
      INSERT INTO profiles (id, email, first_name, last_name)
      VALUES ($1, $2, $3, $4)
    `, [user.id, email, firstName, lastName]);

    return user.id;
  });

  await sendVerificationEmail(userId, email);

  return c.json({ message: 'Registrierung erfolgreich. Bitte E-Mail bestätigen.' }, 201);
});

// ─── POST /auth/login ────────────────────────────────────────────────────────
const loginSchema = z.object({
  email:    z.string().email().toLowerCase(),
  password: z.string(),
});

auth.post('/login', zValidator('json', loginSchema), async (c) => {
  const { email, password } = c.req.valid('json');
  const ip = c.req.header('x-forwarded-for') ?? 'unknown';
  const ua = c.req.header('user-agent') ?? '';

  const user = await db.oneOrNone(`
    SELECT id, password_hash, role, email_verified, is_banned
    FROM users WHERE email = $1
  `, [email]);

  // Immer hashen, auch wenn User nicht existiert (verhindert Timing Attack)
  const dummyHash = '$2b$12$invalidhashtopreventtimingattack.....';
  const isValid = await verifyPassword(
    password,
    user?.password_hash ?? dummyHash
  );

  if (!user || !isValid) {
    return c.json({ error: 'Ungültige E-Mail oder Passwort.' }, 401);
  }

  if (user.is_banned) {
    return c.json({ error: 'Konto gesperrt.' }, 403);
  }

  if (!user.email_verified) {
    return c.json({ error: 'E-Mail nicht bestätigt. Bitte zuerst verifizieren.' }, 403);
  }

  const accessToken = signAccessToken({ userId: user.id, role: user.role });
  const refreshToken = await createRefreshToken(user.id, ip, ua);

  // Refresh Token als httpOnly Cookie (nicht per JS auslesbar)
  setCookie(c, 'refresh_token', refreshToken, {
    httpOnly: true,
    secure: true,
    sameSite: 'Strict',
    maxAge: 60 * 60 * 24 * 7, // 7 Tage
    path: '/auth/refresh',     // Cookie nur für diesen Pfad gesendet
  });

  return c.json({ accessToken, role: user.role });
});

// ─── POST /auth/refresh ──────────────────────────────────────────────────────
auth.post('/refresh', async (c) => {
  const { getCookie } = await import('hono/cookie');
  const rawToken = getCookie(c, 'refresh_token');
  if (!rawToken) return c.json({ error: 'Kein Refresh Token.' }, 401);

  const ip = c.req.header('x-forwarded-for') ?? 'unknown';
  const ua = c.req.header('user-agent') ?? '';

  const result = await rotateRefreshToken(rawToken, ip, ua);
  if (!result) {
    deleteCookie(c, 'refresh_token');
    return c.json({ error: 'Token ungültig oder abgelaufen.' }, 401);
  }

  const user = await db.one(
    `SELECT role FROM users WHERE id = $1`, [result.userId]
  );

  const accessToken = signAccessToken({ userId: result.userId, role: user.role });

  setCookie(c, 'refresh_token', result.newRawToken, {
    httpOnly: true,
    secure: true,
    sameSite: 'Strict',
    maxAge: 60 * 60 * 24 * 7,
    path: '/auth/refresh',
  });

  return c.json({ accessToken });
});

// ─── POST /auth/logout ───────────────────────────────────────────────────────
auth.post('/logout', async (c) => {
  const { getCookie } = await import('hono/cookie');
  const rawToken = getCookie(c, 'refresh_token');

  if (rawToken) {
    const tokenHash = hashToken(rawToken);
    // Token invalidieren (nicht nur Cookie löschen)
    await db.none(
      `DELETE FROM refresh_tokens WHERE token_hash = $1`, [tokenHash]
    );
  }

  deleteCookie(c, 'refresh_token', { path: '/auth/refresh' });
  return c.json({ message: 'Abgemeldet.' });
});

// ─── POST /auth/forgot-password ──────────────────────────────────────────────
auth.post('/forgot-password', async (c) => {
  const { email } = await c.req.json();

  const user = await db.oneOrNone(
    `SELECT id FROM users WHERE email = $1`, [email?.toLowerCase()]
  );

  // Immer gleiche Antwort – verhindert User-Enumeration
  if (user) {
    const rawToken = generateToken(32);
    const tokenHash = hashToken(rawToken);
    const expiresAt = new Date(Date.now() + 60 * 60 * 1000); // 1 Stunde

    // Alte Reset-Tokens invalidieren
    await db.none(
      `DELETE FROM password_resets WHERE user_id = $1 AND used_at IS NULL`,
      [user.id]
    );

    await db.none(`
      INSERT INTO password_resets (user_id, token_hash, expires_at)
      VALUES ($1, $2, $3)
    `, [user.id, tokenHash, expiresAt]);

    await sendPasswordResetEmail(email, rawToken);
  }

  return c.json({ message: 'Falls die E-Mail existiert, wurde ein Reset-Link gesendet.' });
});

// ─── POST /auth/reset-password ───────────────────────────────────────────────
const resetSchema = z.object({
  token:    z.string(),
  password: z.string().min(8).max(128),
});

auth.post('/reset-password', zValidator('json', resetSchema), async (c) => {
  const { token, password } = c.req.valid('json');
  const tokenHash = hashToken(token);

  const reset = await db.oneOrNone(`
    SELECT id, user_id FROM password_resets
    WHERE token_hash = $1
      AND used_at IS NULL
      AND expires_at > NOW()
  `, [tokenHash]);

  if (!reset) return c.json({ error: 'Token ungültig oder abgelaufen.' }, 400);

  const newHash = await hashPassword(password);

  await db.tx(async t => {
    await t.none(
      `UPDATE users SET password_hash = $1 WHERE id = $2`,
      [newHash, reset.user_id]
    );
    await t.none(
      `UPDATE password_resets SET used_at = NOW() WHERE id = $1`,
      [reset.id]
    );
    // Alle aktiven Refresh Tokens des Users invalidieren (Session-Reset nach PW-Änderung)
    await t.none(
      `DELETE FROM refresh_tokens WHERE user_id = $1`,
      [reset.user_id]
    );
  });

  return c.json({ message: 'Passwort erfolgreich geändert. Bitte neu einloggen.' });
});

export default auth;
```

### 5.5 Auth Middleware

```typescript
// src/middleware/auth.ts
import { Context, Next } from 'hono';
import { verifyAccessToken } from '../utils/jwt';

export const authMiddleware = async (c: Context, next: Next) => {
  const header = c.req.header('Authorization');
  if (!header?.startsWith('Bearer ')) {
    return c.json({ error: 'Unauthorized' }, 401);
  }

  const token = header.replace('Bearer ', '');
  try {
    const payload = verifyAccessToken(token);
    c.set('user', payload);
    await next();
  } catch {
    return c.json({ error: 'Token ungültig oder abgelaufen.' }, 401);
  }
};

// Role-based Guard
export const requireRole = (roles: string[]) =>
  async (c: Context, next: Next) => {
    const user = c.get('user');
    if (!roles.includes(user.role)) {
      return c.json({ error: 'Forbidden' }, 403);
    }
    await next();
  };
```

### 5.6 Rate Limiting (Brute-Force-Schutz)

```typescript
// src/middleware/rateLimit.ts
import { rateLimiter } from 'hono-rate-limiter';

// Auth-Endpoints: max 10 Versuche in 15 Minuten
export const authRateLimit = rateLimiter({
  windowMs: 15 * 60 * 1000,
  limit: 10,
  keyGenerator: (c) =>
    c.req.header('x-forwarded-for') ?? c.req.raw.socket?.remoteAddress ?? 'unknown',
  message: { error: 'Zu viele Versuche. Bitte in 15 Minuten erneut versuchen.' },
});

// API-Endpoints: großzügiger
export const apiRateLimit = rateLimiter({
  windowMs: 60 * 1000,
  limit: 100,
});
```

```typescript
// src/index.ts – Rate Limiter auf Auth-Routen anwenden
app.use('/auth/login', authRateLimit);
app.use('/auth/register', authRateLimit);
app.use('/auth/forgot-password', authRateLimit);
app.use('/auth/reset-password', authRateLimit);
```

