# 10. PgBouncer starten
sudo systemctl enable pgbouncer && sudo systemctl start pgbouncer

# Verifizierung
psql -U freyone_api -d freyone_prod -c "\dt"          # alle Tabellen listen
psql -U freyone_api -d freyone_prod -c "\d users"     # Auth-Tabelle prüfen
psql -U freyone_api -d freyone_prod -c "\d provider_profiles" # noch 47 Spalten?
psql -U freyone_api -d freyone_prod -c "\d provider_business_details"
```

