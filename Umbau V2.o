[databases]
freyone_prod     = host=localhost port=5432 dbname=freyone_prod
company_internal = host=localhost port=5432 dbname=company_internal

[pgbouncer]
listen_port      = 6432
listen_addr      = localhost
pool_mode        = transaction
max_client_conn  = 200
